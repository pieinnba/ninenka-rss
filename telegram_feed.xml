    <item>
      <title>🎉 Відбувся реліз Digimon Story Time Stranger для Nintendo Switch та Nintendo Switch 2</title>
      <link>https://t.me/ninenka/5983</link>
      <guid isPermaLink="true">https://t.me/ninenka/5983</guid>
      <pubDate>Sun, 12 Jul 2026 15:29:31 GMT</pubDate>
